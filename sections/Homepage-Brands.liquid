      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "visible_if": "{{ section.settings.description != blank }}"
    },

    {
      "type": "header",
      "content": "Colors (Controls)"
    },
    {
      "type": "color",
      "id": "nav_bg_color",
      "label": "Arrow background",
      "default": "rgba(0,0,0,0.55)"
    },
    {
      "type": "color",
      "id": "nav_icon_color",
      "label": "Arrow icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "dots_color",
      "label": "Dots color",
      "default": "#000000"
    },

    {
      "type": "header",
      "content": "Colors (Placeholder)"
    },
    {
      "type": "color",
      "id": "placeholder_bg",
      "label": "Placeholder background",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "placeholder_text",
      "label": "Placeholder text",
      "default": "#999999"
    },

    {
      "type": "header",
      "content": "Spacing"
    },
