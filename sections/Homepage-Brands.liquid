      "max": 100,
      "unit": "px",
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "unit": "px",
      "step": 1,
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
