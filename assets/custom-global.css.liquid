/* ========================================
   GLOBAL THEME VARIABLES & UTILITIES
   ======================================== */

/* CSS Reset & Base Styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

/* ========================================
   THEME GLOBAL VARIABLES
   ======================================== */

:root {
  /* ========================================
     PAGE LAYOUT & WIDTHS
     ======================================== */
  --page-width: {{ settings.page_width }};
  --sidebar-width: 25rem;
  --narrow-content-width: 36rem;
  --normal-content-width: 42rem;
  --wide-content-width: 46rem;
  --narrow-page-width: 90rem;
  --normal-page-width: 120rem;
  --wide-page-width: 150rem;

  /* ========================================
     SECTION HEIGHTS
     ======================================== */
  --section-height-small: 15rem;
  --section-height-medium: 25rem;
  --section-height-large: 35rem;

  @media screen and (min-width: 40em) {
    --section-height-small: 40svh;
    --section-height-medium: 55svh;
    --section-height-large: 70svh;
  }

  @media screen and (min-width: 60em) {
    --section-height-small: 50svh;
    --section-height-medium: 65svh;
    --section-height-large: 80svh;
  }

  /* ========================================
     TYPOGRAPHY - FONT FAMILIES
     ======================================== */
  --font-body--family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
  --font-body--style: {{ settings.type_body_font.style }};
  --font-body--weight: {{ settings.type_body_font.weight }};
  
  --font-subheading--family: {{ settings.type_subheading_font.family }}, {{ settings.type_subheading_font.fallback_families }};
  --font-subheading--style: {{ settings.type_subheading_font.style }};
  --font-subheading--weight: {{ settings.type_subheading_font.weight }};
  
  --font-heading--family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
  --font-heading--style: {{ settings.type_heading_font.style }};
  --font-heading--weight: {{ settings.type_heading_font.weight }};
  
  --font-accent--family: {{ settings.type_accent_font.family }}, {{ settings.type_accent_font.fallback_families }};
  --font-accent--style: {{ settings.type_accent_font.style }};
  --font-accent--weight: {{ settings.type_accent_font.weight }};

  /* ========================================
     TYPOGRAPHY - FONT SIZES
     ======================================== */
  --font-size-paragraph: {{ settings.type_size_paragraph }}px;
  --font-size-h1: {{ settings.type_size_h1 }}px;
  --font-size-h2: {{ settings.type_size_h2 }}px;
  --font-size-h3: {{ settings.type_size_h3 }}px;
  --font-size-h4: {{ settings.type_size_h4 }}px;
  --font-size-h5: {{ settings.type_size_h5 }}px;
  --font-size-h6: {{ settings.type_size_h6 }}px;

  /* ========================================
     TYPOGRAPHY - LINE HEIGHTS
     ======================================== */
  --line-height-paragraph: {{ settings.type_line_height_paragraph }};
  --line-height-h1: {{ settings.type_line_height_h1 }};
  --line-height-h2: {{ settings.type_line_height_h2 }};
  --line-height-h3: {{ settings.type_line_height_h3 }};
  --line-height-h4: {{ settings.type_line_height_h4 }};
  --line-height-h5: {{ settings.type_line_height_h5 }};
  --line-height-h6: {{ settings.type_line_height_h6 }};

  /* ========================================
     TYPOGRAPHY - LETTER SPACING
     ======================================== */
  --letter-spacing-h1: {{ settings.type_letter_spacing_h1 }};
  --letter-spacing-h2: {{ settings.type_letter_spacing_h2 }};
  --letter-spacing-h3: {{ settings.type_letter_spacing_h3 }};
  --letter-spacing-h4: {{ settings.type_letter_spacing_h4 }};
  --letter-spacing-h5: {{ settings.type_letter_spacing_h5 }};
  --letter-spacing-h6: {{ settings.type_letter_spacing_h6 }};

  /* ========================================
     TYPOGRAPHY - TEXT CASES
     ======================================== */
  --text-case-h1: {{ settings.type_case_h1 }};
  --text-case-h2: {{ settings.type_case_h2 }};
  --text-case-h3: {{ settings.type_case_h3 }};
  --text-case-h4: {{ settings.type_case_h4 }};
  --text-case-h5: {{ settings.type_case_h5 }};
  --text-case-h6: {{ settings.type_case_h6 }};

  /* ========================================
     TYPOGRAPHY - FONT PRESETS
     ======================================== */
  --font-h1: {{ settings.type_font_h1 }};
  --font-h2: {{ settings.type_font_h2 }};
  --font-h3: {{ settings.type_font_h3 }};
  --font-h4: {{ settings.type_font_h4 }};
  --font-h5: {{ settings.type_font_h5 }};
  --font-h6: {{ settings.type_font_h6 }};

  /* ========================================
     BUTTON SETTINGS
     ======================================== */
  /* Primary Button */
  --primary-button-border-width: {{ settings.primary_button_border_width }}px;
  --primary-button-border-radius: {{ settings.button_border_radius_primary }}px;
  --primary-button-font: {{ settings.type_font_button_primary }};
  --primary-button-font-weight: {{ settings.button_font_weight_primary }};
  --primary-button-text-case: {{ settings.button_text_case_primary }};
  --primary-button-background-color: {{ settings.primary_button_background_color }};
  --primary-button-text-color: {{ settings.primary_button_text_color }};
  --primary-button-border-color: {{ settings.primary_button_border_color }};
  --primary-button-hover-background-color: {{ settings.primary_button_hover_background_color }};
  --primary-button-hover-text-color: {{ settings.primary_button_hover_text_color }};
  --primary-button-hover-border-color: {{ settings.primary_button_hover_border_color }};

  /* Secondary Button */
  --secondary-button-border-width: {{ settings.secondary_button_border_width }}px;
  --secondary-button-border-radius: {{ settings.button_border_radius_secondary }}px;
  --secondary-button-font: {{ settings.type_font_button_secondary }};
  --secondary-button-font-weight: {{ settings.button_font_weight_secondary }};
  --secondary-button-text-case: {{ settings.button_text_case_secondary }};
  --secondary-button-background-color: {{ settings.secondary_button_background_color }};
  --secondary-button-text-color: {{ settings.secondary_button_text_color }};
  --secondary-button-border-color: {{ settings.secondary_button_border_color }};
  --secondary-button-hover-background-color: {{ settings.secondary_button_hover_background_color }};
  --secondary-button-hover-text-color: {{ settings.secondary_button_hover_text_color }};
  --secondary-button-hover-border-color: {{ settings.secondary_button_hover_border_color }};

  /* Pills */
  --pills-border-radius: {{ settings.pills_border_radius }}px;

  /* ========================================
     CART SETTINGS
     ======================================== */
  --cart-type: {{ settings.cart_type }};
  --cart-price-font: {{ settings.cart_price_font }};
  --show-cart-note: {{ settings.show_cart_note }};
  --show-add-discount-code: {{ settings.show_add_discount_code }};
  --show-installments: {{ settings.show_installments }};
  --show-accelerated-checkout: {{ settings.show_accelerated_checkout_buttons }};

  /* ========================================
     DRAWER SETTINGS
     ======================================== */
  --drawer-color-scheme: {{ settings.drawer_color_scheme }};
  --drawer-border: {{ settings.drawer_border }};
  --drawer-border-width: {{ settings.drawer_border_width }}px;
  --drawer-border-opacity: {{ settings.drawer_border_opacity }}%;
  --drawer-drop-shadow: {{ settings.drawer_drop_shadow }};

  /* ========================================
     ICON SETTINGS
     ======================================== */
  --icon-stroke: {{ settings.icon_stroke }};

  /* ========================================
     INPUT FIELD SETTINGS
     ======================================== */
  --input-border-width: {{ settings.input_border_width }}px;
  --input-border-radius: {{ settings.inputs_border_radius }}px;
  --input-type-preset: {{ settings.type_preset }};

  /* ========================================
     POPOVER & MODAL SETTINGS
     ======================================== */
  --popover-color-scheme: {{ settings.popover_color_scheme }};
  --popover-border-radius: {{ settings.popover_border_radius }}px;
  --popover-border: {{ settings.popover_border }};
  --popover-border-width: {{ settings.popover_border_width }}px;
  --popover-border-opacity: {{ settings.popover_border_opacity }}%;
  --popover-drop-shadow: {{ settings.popover_drop_shadow }};

  /* ========================================
     PRICE DISPLAY SETTINGS
     ======================================== */
  --currency-code-product-pages: {{ settings.currency_code_enabled_product_pages }};
  --currency-code-product-cards: {{ settings.currency_code_enabled_product_cards }};
  --currency-code-cart-items: {{ settings.currency_code_enabled_cart_items }};
  --currency-code-cart-total: {{ settings.currency_code_enabled_cart_total }};

  /* ========================================
     PRODUCT CARD SETTINGS
     ======================================== */
  --quick-add-enabled: {{ settings.quick_add }};
  --mobile-quick-add: {{ settings.mobile_quick_add }};
  --quick-add-color-scheme: {{ settings.quick_add_color_scheme }};
  --show-second-image-hover: {{ settings.show_second_image_on_hover }};
  --product-card-carousel: {{ settings.product_card_carousel }};

  /* ========================================
     SEARCH SETTINGS
     ======================================== */
  --empty-state-collection: {{ settings.empty_state_collection }};
  --product-corner-radius: {{ settings.product_corner_radius }}px;
  --card-corner-radius: {{ settings.card_corner_radius }}px;
  --card-title-case: {{ settings.card_title_case }};

  /* ========================================
     VARIANT SWATCH SETTINGS
     ======================================== */
  --show-variant-image: {{ settings.show_variant_image }};
  --variant-swatch-width: {{ settings.variant_swatch_width }}px;
  --variant-swatch-height: {{ settings.variant_swatch_height }}px;
  --variant-swatch-radius: {{ settings.variant_swatch_radius }}px;
  --variant-swatch-border-style: {{ settings.variant_swatch_border_style }};
  --variant-swatch-border-width: {{ settings.variant_swatch_border_width }}px;
  --variant-swatch-border-opacity: {{ settings.variant_swatch_border_opacity }}%;

  /* ========================================
     VARIANT PICKER SETTINGS
     ======================================== */
  --variant-button-border-width: {{ settings.variant_button_border_width }}px;
  --variant-button-radius: {{ settings.variant_button_radius }}px;
  --variant-button-width: {{ settings.variant_button_width }};

  /* ========================================
     ANIMATION SETTINGS
     ======================================== */
  --page-transition-enabled: {{ settings.page_transition_enabled }};
  --transition-to-main-product: {{ settings.transition_to_main_product }};
  --add-to-cart-animation: {{ settings.add_to_cart_animation }};
  --card-hover-effect: {{ settings.card_hover_effect }};

  /* ========================================
     BADGE SETTINGS
     ======================================== */
  --badge-position: {{ settings.badge_position }};
  --badge-corner-radius: {{ settings.badge_corner_radius }}px;
  --badge-sale-color-scheme: {{ settings.badge_sale_color_scheme }};
  --badge-sold-out-color-scheme: {{ settings.badge_sold_out_color_scheme }};
  --badge-text-transform: {{ settings.badge_text_transform }};

  /* ========================================
     CART THUMBNAIL SETTINGS
     ======================================== */
  --cart-thumbnail-border: {{ settings.cart_thumbnail_border }};
  --cart-thumbnail-border-width: {{ settings.cart_thumbnail_border_width }}px;
  --cart-thumbnail-border-opacity: {{ settings.cart_thumbnail_border_opacity }}%;
  --cart-thumbnail-border-radius: {{ settings.cart_thumbnail_border_radius }}px;

  /* ========================================
     PRODUCT TITLE SETTINGS
     ======================================== */
  --product-title-case: {{ settings.product_title_case }};

  /* ========================================
     LOGO & FAVICON
     ======================================== */
  --logo: {{ settings.logo }};
  --logo-inverse: {{ settings.logo_inverse }};
  --favicon: {{ settings.favicon }};


  /* ========================================
     COLOR SETTINGS
     ======================================== */
  --global-main-color: {{ settings.main_color }};
  --global-secondary-color: {{ settings.secondary_color }};  
  --global-tertiary-color: {{ settings.tertiary_color }};
}

