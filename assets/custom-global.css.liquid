/* display */
.d-none { display: none; }
.d-block { display: block; }
.d-inline { display: inline; }
.d-inline-block { display: inline-block; }
.d-flex { display: flex; }
.d-inline-flex { display: inline-flex; }

.for-desktop {
  display: block !important;
}
.for-mobile {
  display: none !important;
}
@media screen and (max-width: 768px) {
  .for-desktop {
    display: none !important;
  }
  .for-mobile {
    display: block !important;
  }
}
/* Button Classes */
.btn-primary {
  border-width: var(--primary-button-border-width);
  border-radius: var(--primary-button-border-radius);
  font-family: var(--font-{{ settings.type_font_button_primary }}--family);
  font-weight: var(--primary-button-font-weight);
  text-transform: var(--primary-button-text-case);
  background-color: #E32626 !important;
    color: white !important;
  border-color: var(--primary-button-border-color);
  &:hover {
    background-color: black !important;
    color: white !important;
    border-color: var(--primary-button-hover-border-color);
  }
}

.btn-secondary {
  border-width: var(--secondary-button-border-width);
  border-radius: var(--secondary-button-border-radius);
  font-family: var(--font-{{ settings.type_font_button_secondary }}--family);
  font-weight: var(--secondary-button-font-weight);
  text-transform: var(--secondary-button-text-case);
  background-color: var(--secondary-button-background-color);
  color: var(--secondary-button-text-color);
  border-color: var(--secondary-button-border-color);
  &:hover {
    background-color: var(--secondary-button-hover-background-color);
    color: var(--secondary-button-hover-text-color);
    border-color: var(--secondary-button-hover-border-color);
  }
}

.btn-link {
  text-decoration: underline;
  color: var(--primary-button-text-color);
  &:hover {
    color: var(--primary-button-hover-text-color);
  }
}

/* Typography Classes */
.heading-1 {
  font-size: var(--font-size-h1);
  font-family: var(--font-{{ settings.type_font_h1 }}--family);
  line-height: var(--line-height-h1);
  letter-spacing: var(--letter-spacing-h1);
  text-transform: var(--text-case-h1);
}

.heading-2 {
  font-size: var(--font-size-h2);
  font-family: var(--font-{{ settings.type_font_h2 }}--family);
  line-height: var(--line-height-h2);
  letter-spacing: var(--letter-spacing-h2);
  text-transform: var(--text-case-h2);
}

.heading-3 {
  font-size: var(--font-size-h3);
  font-family: var(--font-{{ settings.type_font_h3 }}--family);
  line-height: var(--line-height-h3);
  letter-spacing: var(--letter-spacing-h3);
  text-transform: var(--text-case-h3);
}

.heading-4 {
  font-size: var(--font-size-h4);
  font-family: var(--font-{{ settings.type_font_h4 }}--family);
  line-height: var(--line-height-h4);
  letter-spacing: var(--letter-spacing-h4);
  text-transform: var(--text-case-h4);
}

.heading-5 {
  font-size: var(--font-size-h5);
  font-family: var(--font-{{ settings.type_font_h5 }}--family);
  line-height: var(--line-height-h5);
  letter-spacing: var(--letter-spacing-h5);
  text-transform: var(--text-case-h5);
}

.heading-6 {
  font-size: var(--font-size-h6);
  font-family: var(--font-{{ settings.type_font_h6 }}--family);
  line-height: var(--line-height-h6);
  letter-spacing: var(--letter-spacing-h6);
  text-transform: var(--text-case-h6);
}

.body-text {
  font-size: var(--font-size-paragraph);
  font-family: var(--font-body--family);
  line-height: var(--line-height-paragraph);
}

/* width */
.narrow-width {
  max-width: var(--narrow-page-width);
  width: 100%;
  margin: 0 auto;
  /* padding: 0 20px; */
}

.full-width {
  width: 100%;
  margin: 0 auto;
}