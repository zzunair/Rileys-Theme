{%- liquid
  assign s = block.settings
  
  # Check if user wants to use Global Data or Override it
  if s.use_global_data
    assign phone_to_display = settings.global_phone_number
    assign address_to_display = settings.global_address
  else
    assign phone_to_display = s.global_phone_number
    assign address_to_display = s.global_address
  endif
-%}

<div
  class="header-contact-inline"
  style="
    --hc-gap: {{ s.gap }}px;
    --hc-text-color: {{ s.text_color }};
    --hc-text-size: {{ s.text_size }}px;
    --hc-icon-size: {{ s.icon_size }}px;
    --hc-btn-text: {{ s.button_text_color }};
    --hc-btn-bg: {{ s.button_bg_color }};
    --hc-btn-border: {{ s.button_border_color }};
    --hc-btn-radius: {{ s.button_radius }}px;
    --hc-max-width: {{ s.max_width }}px;
    --hc-flex: {% if s.allow_grow %}1 1 auto{% else %}0 0 auto{% endif %};
  "
  {{ block.shopify_attributes }}
>
  {% if phone_to_display != blank %}
    <span class="hc-item">
      {% if s.phone_icon != blank %}
        <span class="hc-icon">
          <img src="{{ s.phone_icon | image_url: width: 48 }}" alt="" width="{{ s.icon_size }}" height="{{ s.icon_size }}" loading="lazy">
        </span>
      {% endif %}
      <a class="hc-text hc-link" href="tel:{{ phone_to_display | remove: ' ' }}">{{ phone_to_display }}</a>
    </span>
  {% endif %}

  {% if address_to_display != blank %}
    <span class="hc-item">
      {% if s.address_icon != blank %}
        <span class="hc-icon">
          <img src="{{ s.address_icon | image_url: width: 48 }}" alt="" width="{{ s.icon_size }}" height="{{ s.icon_size }}" loading="lazy">
        </span>
      {% endif %}
      <span class="hc-text">{{ address_to_display }}</span>
    </span>
  {% endif %}

  {% if s.button_label != blank %}
    <a class="hc-btn" href="{{ s.button_link | default: '#' }}">
      {% if s.button_icon != blank %}
        <span class="hc-icon">
          <img src="{{ s.button_icon | image_url: width: 48 }}" alt="" width="{{ s.icon_size }}" height="{{ s.icon_size }}" loading="lazy">
        </span>
      {% endif %}
      {{ s.button_label }}
    </a>
  {% endif %}
</div>

{% stylesheet %}
 .header-contact-inline {
    display: inline-flex;
    align-items: center;
    gap: var(--hc-gap);
    white-space: nowrap;
    flex: var(--hc-flex, 0 0 auto);
    max-width: var(--hc-max-width);
    overflow: hidden;
}
.hc-item { display: inline-flex; align-items: center; gap: 8px; min-width: 0; }
.hc-icon { width: var(--hc-icon-size); height: var(--hc-icon-size); display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; }
.hc-icon img { width: 100%; height: 100%; object-fit: contain; }
.hc-text { color: var(--hc-text-color); font-size: var(--hc-text-size); line-height: 1.2; overflow: hidden; text-overflow: ellipsis; }
.hc-link { color: var(--hc-text-color); text-decoration: none; font-weight: 600; }
.hc-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 14px; border-radius: var(--hc-btn-radius); border: 1px solid var(--hc-btn-border); background: var(--hc-btn-bg); color: var(--hc-btn-text); text-decoration: none; font-weight: 600; }
@media screen and (max-width: 749px) { .header-contact-inline { display: none !important; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Header contact",
  "class": "header-contact",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_global_data",
      "label": "Use Global Data Settings",
      "default": true,
      "info": "Uncheck this to use the custom 'Re-edit' fields below."
    },
    { "type": "header", "content": "Re-edit Custom Data" },
    { "type": "text", "id": "global_phone_number", "label": "Custom Phone Number" },
    { "type": "text", "id": "global_address", "label": "Custom Address" },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Map & Hours" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Icons" },
    { "type": "image_picker", "id": "phone_icon", "label": "Phone icon" },
    { "type": "image_picker", "id": "address_icon", "label": "Address icon" },
    { "type": "image_picker", "id": "button_icon", "label": "Button icon" },

    { "type": "header", "content": "Styles" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "range", "id": "text_size", "label": "Text size (px)", "min": 10, "max": 20, "step": 1, "default": 14 },
    { "type": "range", "id": "icon_size", "label": "Icon size (px)", "min": 10, "max": 24, "step": 1, "default": 16 },
    { "type": "range", "id": "gap", "label": "Gap (px)", "min": 4, "max": 90, "step": 1, "default": 14 },

    { "type": "header", "content": "Button styles" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "color", "id": "button_bg_color", "label": "Button background color", "default": "#111111" },
    { "type": "color", "id": "button_border_color", "label": "Button border color", "default": "#111111" },
    { "type": "range", "id": "button_radius", "label": "Button radius (px)", "min": 0, "max": 30, "step": 1, "default": 6 },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 120, "max": 1400, "step": 20, "default": 420 },
    { "type": "checkbox", "id": "allow_grow", "label": "Allow it to grow", "default": false }
  ]
}
{% endschema %}