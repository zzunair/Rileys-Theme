<style>
  .store-location-block {
    box-sizing: border-box;
  }

  .sl-title {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 20px 0;
    padding: 0;
  }

  .sl-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 20px;
  }

  .sl-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
   
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sl-icon svg {
    width: 20px;
    height: 20px;
  }

  .sl-content {
    font-size: 14px;
    line-height: 1.7;
    padding-top: 3px;
  }

  .sl-content p {
    margin: 0 0 4px 0;
  }

  .sl-content p:last-child {
    margin-bottom: 0;
  }

  .sl-map-link {
    margin-top: 8px;
  }

  .sl-map-link a {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-bottom: 2px solid;
    padding-bottom: 2px;
    transition: opacity 0.2s ease;
  }

  .sl-map-link a:hover {
    opacity: 0.7;
  }
</style>

<div class="store-location-block" >

  {% if block.settings.title != blank %}
    <h3 class="sl-title" style="color: {{ block.settings.title_color }};">
      {{ block.settings.title }}
    </h3>
  {% endif %}

  {% if block.settings.row1_content != blank %}
    <div class="sl-row">
      <div class="sl-icon" style="background-color: {{ block.settings.row1_icon_bg }};">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
      </div>
      <div class="sl-content" style="color: {{ block.settings.row1_text_color }};">
        {{ block.settings.row1_content }}
      </div>
    </div>
  {% endif %}

  {% if block.settings.row2_content != blank %}
    <div class="sl-row">
      <div class="sl-icon" style="background-color: {{ block.settings.row2_icon_bg }};">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <div class="sl-content" style="color: {{ block.settings.row2_text_color }};">
        {{ block.settings.row2_content }}
      </div>
    </div>
  {% endif %}

  {% if block.settings.row3_content != blank %}
    <div class="sl-row">
      <div class="sl-icon" style="background-color: {{ block.settings.row3_icon_bg }};">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.44 2 2 0 0 1 3.59 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/>
        </svg>
      </div>
      <div class="sl-content" style="color: {{ block.settings.row3_text_color }};">
        {{ block.settings.row3_content }}
      </div>
    </div>
  {% endif %}

  {% if block.settings.map_link != blank %}
    <div class="sl-map-link">
      <a href="{{ block.settings.map_link }}" target="_blank" style="color: {{ block.settings.link_color }}; border-bottom-color: {{ block.settings.link_color }};">
        {{ block.settings.map_link_text | default: 'VIEW MAP' }}
      </a>
    </div>
  {% endif %}

</div>

{% schema %}
{
  "name": "Store Location",
  "settings": [
   
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "STORE LOCATION"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Row 1 — Address"
    },
    {
      "type": "richtext",
      "id": "row1_content",
      "label": "Address",
      "default": "<p>Add your address here</p>"
    },
    {
      "type": "color",
      "id": "row1_icon_bg",
      "label": "Row 1 Icon Color",
      "default": "#cc0000"
    },
    {
      "type": "color",
      "id": "row1_text_color",
      "label": "Row 1 Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Row 2 — Hours"
    },
    {
      "type": "richtext",
      "id": "row2_content",
      "label": "Hours",
      "default": "<p>Add your hours here</p>"
    },
    {
      "type": "color",
      "id": "row2_icon_bg",
      "label": "Row 2 Icon Color",
      "default": "#cc0000"
    },
    {
      "type": "color",
      "id": "row2_text_color",
      "label": "Row 2 Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Row 3 — Phone (optional)"
    },
    {
      "type": "richtext",
      "id": "row3_content",
      "label": "Phone"
    },
    {
      "type": "color",
      "id": "row3_icon_bg",
      "label": "Row 3 Icon Color",
      "default": "#cc0000"
    },
    {
      "type": "color",
      "id": "row3_text_color",
      "label": "Row 3 Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Map Link"
    },
    {
      "type": "url",
      "id": "map_link",
      "label": "Map URL"
    },
    {
      "type": "text",
      "id": "map_link_text",
      "label": "Map Link Label",
      "default": "VIEW MAP"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Location",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
